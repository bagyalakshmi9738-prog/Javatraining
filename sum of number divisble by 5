public class SumDivisibleBy5 {
    public static void main(String[] args) {
        int limit = 50; 
        int sum = 0;

        for (int i = 1; i <= limit; i++) {
            if (i % 5 == 0) {
                sum += i;
            }
        }

        System.out.println("Sum of numbers divisible by 5: " + sum);
    }
}
